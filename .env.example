# -------------------------------
# 基础配置
# -------------------------------
APP_NAME=Emby TG 管理中心
APP_ENV=production
APP_PORT=18080
# 注意：已取消 Web 面板对外端口映射，APP_PORT 仅保留兼容配置
APP_BASE_URL=http://your-server-ip:18080
APP_TIMEZONE=Asia/Shanghai
APP_MASTER_KEY=change-this-to-a-random-32-char-secret
APP_WEB_ADMIN_USERNAME=admin
APP_WEB_ADMIN_PASSWORD=change-me

# -------------------------------
# Emby 配置
# -------------------------------
# Emby API 地址：项目内部调用这个地址连接 Emby
EMBY_BASE_URL=http://your-emby-host:8096
# Emby API Key：用于校验、创建用户、删用户、改密码、查在线设备
EMBY_API_KEY=replace-with-your-emby-api-key
# 对外显示给用户的服务地址：机器人注册成功、我的账号里会显示这个地址
# 这里可直接修改成你的公网 IP/域名 + Emby 端口
EMBY_SERVER_PUBLIC_URL=http://your-emby-public-host:8096
# 新账号权限复制模板账号，默认 testone
EMBY_TEMPLATE_USER=testone
# 以下用户名在 Emby -> 本地同步时会被忽略，多个用逗号分隔
EMBY_IMPORT_IGNORE_USERNAMES=xiaocai
# Emby -> 本地同步时，仅把本地服务器保存的密码统一写成这个默认值，不会修改 Emby 当前密码
EMBY_SYNC_LOCAL_DEFAULT_PASSWORD=1234
# 本地用户导入到 Emby 时，每个账号之间的间隔秒数，放慢速度避免 Emby 锁库
EMBY_PUSH_SYNC_DELAY_SECONDS=0.6

# -------------------------------
# Telegram 管理员 1 号机器人
# -------------------------------
ADMIN_BOT_TOKEN=replace-with-admin-bot-token
ADMIN_CHAT_IDS=123456789

# -------------------------------
# Telegram 客户机器人
# -------------------------------
CLIENT_BOT_TOKEN=replace-with-client-bot-token

# -------------------------------
# 联系方式 / 文案
# -------------------------------
ADMIN_CONTACT_TG_USERNAME=@your_admin_username
ADMIN_CONTACT_TG_USER_ID=123456789
DEFAULT_USER_EXPIRE_DAYS=90
REGISTER_CODE_LENGTH=16
CODE_BATCH_LIMIT=500
WEB_EXPIRING_SOON_DAYS=3

# -------------------------------
# 后台任务
# -------------------------------
EXPIRY_CHECK_SECONDS=3600
ONLINE_CHECK_SECONDS=60
